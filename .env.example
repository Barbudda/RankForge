# ─────────────────────────────────────────────────────────────
# RankForge — environment variables
# Copy to `.env.local` and fill in. The app ships production-ready
# with NONE of these set: it starts empty (real empty states), and
# the support chatbot falls back to an offline knowledge base.
# Load the labelled sample dataset anytime via the in-app Dev button.
# ─────────────────────────────────────────────────────────────

# Toggle the data/runtime layer. "mock" (default) ships realistic
# fixtures with zero external dependencies. "live" wires the real
# GitHub / crawler / LLM adapters (not all implemented in the MVP).
RANKFORGE_MODE=mock

# Public app URL (used for canonical links, OG tags, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Account owner (solo product — one real user/workspace) ───
# These set the identity shown in the app. All optional; sensible
# defaults are used if unset. NEXT_PUBLIC_* are exposed to the browser.
NEXT_PUBLIC_OWNER_NAME=
NEXT_PUBLIC_OWNER_EMAIL=
NEXT_PUBLIC_OWNER_GITHUB=
NEXT_PUBLIC_OWNER_AVATAR=
NEXT_PUBLIC_WORKSPACE_NAME=

# ── Supabase (database + auth + storage) ────────────────────
# Find these in your Supabase project → Project Settings → API keys.
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (client-safe) key — starts with "sb_publishable_".
# Older projects call this the "anon" key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret (server-only) key — starts with "sb_secret_". NEVER expose to the
# browser / never prefix with NEXT_PUBLIC_. OPTIONAL: nothing reads it today
# (all access is via the publishable key under RLS). Only needed if you later
# add admin/service-role operations.
SUPABASE_SECRET_KEY=

# ── GitHub (OAuth + GitHub App) ──────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Auth ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Database (Postgres — provided by Supabase) ──────────────
# Supabase → Project Settings → Database → Connection string.
# App runtime: use the pooled "Session"/"Transaction" pooler URL.
DATABASE_URL=
# Migrations/introspection: the "Direct connection" (non-pooled) URL.
DIRECT_URL=

# ── Billing (Stripe — mocked in MVP) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── LLM (optional — RankForge works WITHOUT any of this) ─────
# What runs with ZERO config / zero key:
#   • Audits        — 100% deterministic engine (crawl + rules + link graph
#                     + semantic internal-link suggestions). No LLM.
#   • Fixes         — mechanical issues (viewport, lang, canonical, robots,
#                     sitemap, JSON-LD, social) get a deterministic patch.
#   • Support chat  — extractive answers from the local RAG corpus.
# A generative LLM only ADDS: audit content-quality enrichment, fixes for
# judgment-heavy issues, and a generative (vs extractive) chatbot.
#
# Pick ONE generative backend (or none):

# (a) Anthropic API key — production path. Paid per token.
ANTHROPIC_API_KEY=
# Optional model overrides (both default to claude-opus-4-8).
RANKFORGE_CHAT_MODEL=
RANKFORGE_AGENT_MODEL=

# (b) FREE / LOCAL model — Ollama or any OpenAI-compatible endpoint. No key,
#     no billing, runs offline. Install Ollama, `ollama pull llama3.1`, then:
#       RANKFORGE_LLM=ollama
#     Also works with LM Studio / llama.cpp, or a hosted free tier (Groq,
#     Gemini OpenAI-compat) by setting the base URL + a free key below.
# (c) Claude CLI on your Claude Code SUBSCRIPTION (dev only, no API billing):
#       RANKFORGE_LLM=claude-cli
RANKFORGE_LLM=
# Local/OpenAI-compatible model config (only used when RANKFORGE_LLM=ollama|openai-compat):
RANKFORGE_LLM_BASE_URL=http://localhost:11434/v1
RANKFORGE_LLM_MODEL=llama3.1
RANKFORGE_LLM_API_KEY=
# Optional CLI model override when RANKFORGE_LLM=claude-cli (opus/sonnet/haiku).
RANKFORGE_CLI_MODEL=

# ── MCP endpoint (/api/mcp — the RankForge agent in your editor) ──
# Open on localhost in development. A DEPLOYED instance audits PUBLIC URLs
# (it can't reach a user's localhost) and is locked by default. To let others
# connect, pick ONE:
#   • RANKFORGE_MCP_PUBLIC=1     → open the endpoint (SSRF still blocks
#                                  private/internal hosts). Easiest for a demo.
#   • RANKFORGE_MCP_KEY=<secret> → require this as a Bearer token instead.
RANKFORGE_MCP_PUBLIC=
RANKFORGE_MCP_KEY=
